ADMIN_WEB_PORT=8080

# SQLite database is stored in ./data/admin-api/dev.db on the host.
DATABASE_URL=file:/data/dev.db

# Public URL used in update metadata. Use HTTPS domain in production.
PUBLIC_BASE_URL=https://lingai.ziling.site
RELEASES_DIR=/data/releases

# Required for LingCodex session token signing.
# Generate a production value with: openssl rand -base64 48
LINGCODEX_TOKEN_SECRET=
LINGCODEX_TOKEN_TTL_SECONDS=3600

# Optional fallback upstream for proxy requests when a model has no DB provider credentials.
UPSTREAM_OPENAI_URL=
UPSTREAM_OPENAI_KEY=
