generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  username            String?             @unique
  password            String?
  email               String?             @unique
  deviceId            String?             @unique
  quota               Int                 @default(0)
  usedQuota           Int                 @default(0)
  quotaPlanType       String              @default("balance")
  quotaWindowHours    Int?
  quotaWindowLimit    Int?
  quotaWindowUsed     Int                 @default(0)
  quotaWindowStartedAt DateTime?
  quotaWindowEndsAt   DateTime?
  quotaExpiresAt      DateTime?
  cloudHistoryEnabled Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  cardSecrets         CardSecret[]
  cloudConversations  CloudConversation[]
}

model CardSecret {
  id        String    @id @default(uuid())
  code      String    @unique
  amount    Int
  planType  String    @default("balance")
  windowHours Int?
  validDays Int?
  status    String    @default("UNUSED")
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  usedBy    User?     @relation(fields: [usedById], references: [id])
}

/// A Provider groups multiple models that share the same upstream credentials
/// (base URL + API key), mirroring the LingAI client's provider-centric model.
model Provider {
  id        String        @id @default(uuid())
  name      String
  platform  String        @default("custom")
  baseUrl   String?
  apiKey    String?
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  models    ModelConfig[]
}

model ModelConfig {
  id         String    @id @default(uuid())
  modelId    String
  name       String
  providerId String?
  apiBaseUrl String?
  apiKey     String?
  multiplier Float     @default(1.0)
  billingMode String    @default("per_token")
  inputTokenPrice  Float @default(1.0)
  outputTokenPrice Float @default(1.0)
  fixedCost        Int   @default(0)
  minCost          Int   @default(1)
  reserveCost      Int   @default(0)
  sortOrder        Int   @default(0)
  isActive   Boolean   @default(true)
  type       String    @default("chat")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  unitPrice  Float     @default(0)
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, modelId])
  @@index([modelId])
}

model UsageRecord {
  id               String   @id @default(uuid())
  userId           String
  deviceId         String?
  modelId          String
  providerId       String?
  endpoint         String
  billingMode      String
  status           String   @default("SUCCESS")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  reservedPoints   Int      @default(0)
  chargedPoints    Int      @default(0)
  refundedPoints   Int      @default(0)
  detail           String?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([modelId, createdAt])
  @@index([status, createdAt])
}

model FeedbackReport {
  id              String   @id @default(uuid())
  module          String
  moduleLabel     String
  description     String
  status          String   @default("NEW")
  tagsJson        String?
  extraJson       String?
  attachmentsJson String?
  attachmentCount Int      @default(0)
  appVersion      String?
  platform        String?
  userAgent       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([module, createdAt])
}

model CloudConversation {
  id                  String         @id @default(uuid())
  userId              String
  localConversationId String
  name                String
  type                String
  source              String?
  extraJson           String?
  localCreatedAt      DateTime?
  localUpdatedAt      DateTime?
  syncedAt            DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages            CloudMessage[]

  @@unique([userId, localConversationId])
  @@index([userId, syncedAt])
}

model CloudMessage {
  id                  String            @id @default(uuid())
  cloudConversationId String
  localMessageId      String
  msgId               String?
  type                String
  position            String?
  status              String?
  hidden              Boolean           @default(false)
  contentJson         String
  localCreatedAt      DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  conversation        CloudConversation @relation(fields: [cloudConversationId], references: [id], onDelete: Cascade)

  @@unique([cloudConversationId, localMessageId])
  @@index([cloudConversationId, localCreatedAt])
}

model AppRelease {
  id           String   @id @default(uuid())
  version      String
  channel      String   @default("latest")
  platform     String   @default("win32")
  arch         String   @default("x64")
  fileName     String
  sha512       String
  size         Int?
  releaseDate  DateTime @default(now())
  releaseNotes String?
  forceUpdate  Boolean  @default(false)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([channel, platform, arch, version])
}
